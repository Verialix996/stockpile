{
  "expo": {
    "name": "Stockpile",
    "slug": "stockpile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro",
      "backgroundColor": "#0d0f14",
      "themeColor": "#0d0f14",
      "name": "Stockpile",
      "shortName": "Stockpile",
      "description": "Home storage manager",
      "display": "standalone"
    },
    "splash": {
      "backgroundColor": "#0d0f14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.stockpile",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0f14"
      },
      "package": "com.yourname.stockpile",
      "versionCode": 1
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Stockpile uses your photos to attach images to stored items."
        }
      ]
    ]
  }
}
